# Analytics (leave blank to disable)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=

# Contact form (Resend)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@skyride.city
CONTACT_FROM_EMAIL=noreply@skyride.city

# Google Cloud / Vertex AI (Martin chat)
# On Cloud Run these are auto-provided via ADC. For local dev:
# Run `gcloud auth application-default login` or set VERTEX_AI_API_KEY.
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.0-flash
# VERTEX_AI_API_KEY=  # Optional: for local dev without gcloud CLI
